# Desactiva LiteSpeed Cache para todo el subdominio app.yezraelperez.es
# (Hostinger usa LSWS con el módulo LSCache; sin esto cachea respuestas
# y deja la PWA atascada en builds antiguos.)
#
# Usamos dos vías en paralelo — cinturón y tirantes:
#   1) Directivas nativas CacheDisable + CacheLookup off (apaga el módulo).
#   2) Variable de entorno Cache-Control:no-cache por RewriteRule
#      (patrón documentado oficialmente por Hostinger; LSCache la respeta
#      como header HTTP). Cubre el caso de que el módulo de directivas
#      nativas no esté habilitado en la cuenta.
<IfModule LiteSpeed>
  CacheDisable public /
  CacheLookup off
</IfModule>

# SPA fallback + exclusión de cache por ENV var
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Excluir TODO el subdominio del cache de LSWS/LSCache (patrón Hostinger).
  RewriteRule .* - [E=Cache-Control:no-cache]

  # SPA fallback: cualquier ruta que no exista como archivo/carpeta cae a index.html
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Assets con hash en el nombre (Vite) — cache eterno
  <FilesMatch "\.(css|woff2|svg|png|webp)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # JS: por defecto immutable, pero el service worker debe revalidarse siempre
  <FilesMatch "\.js$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^(sw|registerSW|workbox-.*)\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  # Shell HTML + manifest deben ser frescos para que el SW detecte updates
  <FilesMatch "\.(html|webmanifest)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Cabeceras de seguridad
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(self), microphone=(), geolocation=(self), payment=()"
  # CSP: el script de la PWA viene del propio dominio; permitimos conectar a
  # WordPress (REST), tile-server de OpenStreetMap (Leaflet) y geocoder de
  # Nominatim. blob: necesario para algunas operaciones de Vite/Workbox.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://yezraelperez.es https://*.tile.openstreetmap.org https://nominatim.openstreetmap.org; worker-src 'self' blob:; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
</IfModule>
